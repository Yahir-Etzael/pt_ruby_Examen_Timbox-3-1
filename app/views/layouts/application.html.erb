<!DOCTYPE html>
<html>
  <head>
    <title>Examen Rails Full Stack</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if logged_in? %>
      <div class="app-shell" data-controller="sidebar">
        <aside class="sidebar" data-sidebar-target="panel">
          <div class="px-3 py-3 border-bottom">
            <strong>Rails Exam</strong>
            <div class="small text-secondary"><%= current_user.name %></div>
          </div>
          <nav class="nav flex-column p-2">
            <%= link_to "Colaboradores", collaborators_path, class: "nav-link" %>
            <%= link_to "Configuracion de Cuenta", account_settings_path, class: "nav-link" %>
            <%= link_to "Algoritmos", algorithms_path, class: "nav-link" %>
            <%= link_to "Usuarios", managed_users_path, class: "nav-link" %>
            <%= link_to "Servicios", services_path, class: "nav-link" %>
          </nav>
        </aside>
        <main class="content">
          <div class="topbar">
            <button class="btn btn-outline-secondary btn-sm" data-action="sidebar#toggle">Menu</button>
            <%= button_to "Cerrar sesion", logout_path, method: :delete, class: "btn btn-outline-danger btn-sm" %>
          </div>
          <%= render "layouts/flash" %>
          <%= yield %>
        </main>
      </div>
    <% else %>
      <main class="auth-page">
        <%= render "layouts/flash" %>
        <%= yield %>
      </main>
    <% end %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
