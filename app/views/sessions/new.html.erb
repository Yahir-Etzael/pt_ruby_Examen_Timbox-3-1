<section class="page-panel">
  <h1 class="h4 mb-3">Iniciar sesion</h1>
  <%= form_with url: login_path, data: { controller: "form-validation", action: "submit->form-validation#validate" } do |form| %>
    <div class="mb-3">
      <%= form.label :email, "Correo electronico", class: "form-label" %>
      <%= form.email_field :email, class: "form-control", required: true, data: { form_validation_target: "required" } %>
    </div>
    <div class="mb-3">
      <%= form.label :password, "Password", class: "form-label" %>
      <%= form.password_field :password, class: "form-control", required: true, data: { form_validation_target: "required" } %>
    </div>
    <div class="d-flex gap-2">
      <%= form.submit "Entrar", class: "btn btn-primary" %>
      <%= link_to "Registrarme", register_path, class: "btn btn-outline-secondary" %>
    </div>
  <% end %>
  <div class="mt-3">
    <%= link_to "Actualizar password olvidado", new_password_path %>
  </div>
</section>
