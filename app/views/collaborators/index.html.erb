<section class="page-panel">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Colaboradores</h1>
    <%= link_to "Nuevo", new_collaborator_path, class: "btn btn-primary" %>
  </div>
  <div class="table-responsive">
    <table class="table table-striped align-middle">
      <thead><tr><th>Nombre</th><th>Email</th><th>Departamento</th><th>Puesto</th><th>Estado</th><th></th></tr></thead>
      <tbody>
        <% @collaborators.each do |collaborator| %>
          <tr>
            <td><%= collaborator.name %></td>
            <td><%= collaborator.email %></td>
            <td><%= collaborator.department %></td>
            <td><%= collaborator.position %></td>
            <td><%= collaborator.state %></td>
            <td class="text-end">
              <%= link_to "Ver", collaborator, class: "btn btn-sm btn-outline-secondary" %>
              <%= link_to "Editar", edit_collaborator_path(collaborator), class: "btn btn-sm btn-outline-primary" %>
              <%= button_to "Eliminar", collaborator, method: :delete, class: "btn btn-sm btn-outline-danger", form: { data: { turbo_confirm: "Eliminar colaborador?" } } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
