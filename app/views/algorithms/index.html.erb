<section class="page-panel" data-controller="palindrome">
  <h1 class="h3 mb-3">Algoritmos</h1>
  <div class="mb-3">
    <label class="form-label" for="words">Palabras</label>
    <textarea id="words" class="form-control" rows="6" data-palindrome-target="input" placeholder="oso, casa, anita lava la tina"></textarea>
  </div>
  <button class="btn btn-primary" data-action="palindrome#evaluate">Evaluar</button>
  <div class="mt-4" data-palindrome-target="result"></div>
</section>
